<section class="page-hero">
  <div class="container">
    <h1>Contact Us</h1>
    <p>Book a free consultation or reach out with any questions. We respond within 24 hours.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info">
        <span class="section-tag">Get In Touch</span>
        <h2>Let's Talk About Your Business</h2>
        <p>Whether you're ready to get started or just exploring your options, we'd love to hear from you. Our team will respond within one business day.</p>

        <div class="contact-detail">
          <div class="icon"><i class="fas fa-envelope"></i></div>
          <div><h4>Email Us</h4><p>we@finriseadvisors.com</p></div>
        </div>
        <div class="contact-detail">
          <div class="icon"><i class="fas fa-globe"></i></div>
          <div><h4>Website</h4><p>www.finriseadvisors.com</p></div>
        </div>
        <div class="contact-detail">
          <div class="icon"><i class="fas fa-clock"></i></div>
          <div><h4>Business Hours</h4><p>Monday – Friday: 9am – 6pm EST</p></div>
        </div>

        <div style="margin-top:36px;">
          <h4 style="color:var(--navy);margin-bottom:16px;font-weight:700;">Follow Us</h4>
          <div class="social-links" style="gap:12px;">
            <a href="https://www.facebook.com/profile.php?id=61559260650283" target="_blank" style="background:var(--teal-light);color:var(--teal);width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;text-decoration:none;font-size:1.1rem;transition:all 0.3s;"><i class="fab fa-facebook-f"></i></a>
            <a href="https://www.instagram.com/finriseadvisors/" target="_blank" style="background:var(--teal-light);color:var(--teal);width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;text-decoration:none;font-size:1.1rem;transition:all 0.3s;"><i class="fab fa-instagram"></i></a>
            <a href="https://www.linkedin.com/company/101267222/" target="_blank" style="background:var(--teal-light);color:var(--teal);width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;text-decoration:none;font-size:1.1rem;transition:all 0.3s;"><i class="fab fa-linkedin-in"></i></a>
          </div>
        </div>
      </div>

      <div class="contact-form-box">
        <h3 style="color:var(--navy);font-size:1.3rem;font-weight:700;margin-bottom:24px;">Book a Free Consultation</h3>
        <form id="contactForm">
          <div class="form-group">
            <label>Full Name *</label>
            <input type="text" name="name" placeholder="John Smith" required>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div class="form-group">
              <label>Email Address *</label>
              <input type="email" name="email" placeholder="john@company.com" required>
            </div>
            <div class="form-group">
              <label>Phone Number</label>
              <input type="tel" name="phone" placeholder="+1 (555) 000-0000">
            </div>
          </div>
          <div class="form-group">
            <label>Company Name</label>
            <input type="text" name="company" placeholder="Your Company LLC">
          </div>
          <div class="form-group">
            <label>Service Interested In</label>
            <select name="service">
              <option value="">Select a service...</option>
              <option>Outsourced Accounting</option>
              <option>Fractional CFO Services</option>
              <option>Bookkeeping</option>
              <option>Payroll Services</option>
              <option>Construction Accounting</option>
              <option>Tax Compliance</option>
              <option>Not Sure Yet</option>
            </select>
          </div>
          <div class="form-group">
            <label>Message</label>
            <textarea name="message" placeholder="Tell us about your business and what you need help with..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">
            Send Message <i class="fas fa-paper-plane"></i>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

          <li><a href="/services#tax"><i class="fas fa-file-invoice"></i> Tax Compliance</a></li>
        </ul>
      </li>
      <li><a href="/pricing" class="<%= page === 'pricing' ? 'active' : '' %>">Pricing</a></li>
      <li><a href="/resources" class="<%= page === 'resources' ? 'active' : '' %>">Resources</a></li>
      <li><a href="/blog" class="<%= page === 'blog' ? 'active' : '' %>">Blog</a></li>
      <li><a href="/contact-us" class="<%= page === 'contact' ? 'active' : '' %>">Contact</a></li>
    </ul>
    <a href="/contact-us" class="btn-nav">Get Started</a>
    <button class="hamburger" id="hamburger" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>


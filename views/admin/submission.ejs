<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Submission — FinRise Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif; background: #0f172a; color: #e2e8f0; min-height: 100vh; display: flex; }

    /* ── SIDEBAR ── */
    .sidebar {
      width: 240px; min-height: 100vh; background: #1e293b;
      border-right: 1px solid rgba(255,255,255,0.06);
      display: flex; flex-direction: column; padding: 28px 0; flex-shrink: 0;
    }
    .sidebar-brand { padding: 0 24px 28px; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .sidebar-brand-row { display: flex; align-items: center; gap: 10px; }
    .sidebar-icon {
      width: 36px; height: 36px; background: linear-gradient(135deg, #0891b2, #0e7490);
      border-radius: 10px; display: flex; align-items: center; justify-content: center;
      font-size: 1rem; color: white; font-weight: 800;
    }
    .sidebar-brand-name { font-size: 0.9rem; font-weight: 800; color: white; }
    .sidebar-brand-sub { font-size: 0.65rem; color: rgba(255,255,255,0.3); margin-top: 1px; }
    .sidebar-nav { padding: 20px 12px; flex: 1; }
    .sidebar-nav a {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 12px; border-radius: 8px; text-decoration: none;
      color: rgba(255,255,255,0.5); font-size: 0.85rem; font-weight: 500;
      margin-bottom: 4px; transition: all 0.15s;
    }
    .sidebar-nav a:hover { background: rgba(255,255,255,0.05); color: white; }
    .sidebar-nav a.active { background: rgba(8,145,178,0.15); color: #38bdf8; }
    .sidebar-nav .icon { width: 18px; text-align: center; font-size: 0.8rem; }
    .sidebar-footer { padding: 16px 12px 0; border-top: 1px solid rgba(255,255,255,0.06); }
    .sidebar-footer a {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 12px; border-radius: 8px; text-decoration: none;
      color: rgba(255,255,255,0.4); font-size: 0.82rem;
      transition: all 0.15s;
    }
    .sidebar-footer a:hover { background: rgba(239,68,68,0.1); color: #fca5a5; }

    /* ── MAIN ── */
    .main { flex: 1; display: flex; flex-direction: column; min-height: 100vh; }
    .topbar {
      padding: 20px 32px; border-bottom: 1px solid rgba(255,255,255,0.06);
      display: flex; align-items: center; gap: 16px;
      background: rgba(30,41,59,0.5); backdrop-filter: blur(8px);
      position: sticky; top: 0; z-index: 10;
    }
    .back-btn {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
      border-radius: 8px; padding: 8px 14px; color: rgba(255,255,255,0.7);
      font-size: 0.82rem; font-weight: 500; text-decoration: none;
      transition: all 0.15s;
    }
    .back-btn:hover { background: rgba(255,255,255,0.1); color: white; }
    .topbar-title { font-size: 1rem; font-weight: 700; color: white; }
    .topbar-actions { margin-left: auto; display: flex; gap: 10px; }

    .content { padding: 32px; flex: 1; }

    /* ── SUBMISSION LAYOUT ── */
    .sub-grid { display: grid; grid-template-columns: 1fr 320px; gap: 24px; align-items: start; }

    .card {
      background: #1e293b; border: 1px solid rgba(255,255,255,0.07);
      border-radius: 16px; overflow: hidden;
    }
    .card-header {
      padding: 20px 24px; border-bottom: 1px solid rgba(255,255,255,0.06);
      display: flex; align-items: center; justify-content: space-between;
    }
    .card-header h2 { font-size: 0.9rem; font-weight: 700; color: white; }
    .card-body { padding: 24px; }

    /* ── FIELDS ── */
    .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
    .field { margin-bottom: 0; }
    .field-label {
      font-size: 0.7rem; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.8px; color: rgba(255,255,255,0.35); margin-bottom: 6px;
    }
    .field-value {
      font-size: 0.9rem; color: #e2e8f0; font-weight: 500;
      word-break: break-word;
    }
    .field-value a { color: #38bdf8; text-decoration: none; }
    .field-value a:hover { text-decoration: underline; }
    .field-value.empty { color: rgba(255,255,255,0.2); font-style: italic; font-weight: 400; }
    .field-full { margin-bottom: 20px; }
    .message-box {
      background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);
      border-radius: 10px; padding: 16px; font-size: 0.9rem; color: #e2e8f0;
      line-height: 1.7; white-space: pre-wrap; word-break: break-word;
      min-height: 80px;
    }
    .divider { border: none; border-top: 1px solid rgba(255,255,255,0.06); margin: 20px 0; }

    /* ── BADGE ── */
    .badge {
      display: inline-block; padding: 4px 10px; border-radius: 20px;
      font-size: 0.72rem; font-weight: 600;
    }
    .badge-teal { background: rgba(8,145,178,0.15); color: #38bdf8; }
    .badge-amber { background: rgba(245,158,11,0.15); color: #fcd34d; }
    .badge-green { background: rgba(34,197,94,0.15); color: #86efac; }
    .badge-slate { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.5); }

    /* ── META CARD ── */
    .meta-item { margin-bottom: 18px; }
    .meta-item:last-child { margin-bottom: 0; }
    .meta-label {
      font-size: 0.68rem; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.8px; color: rgba(255,255,255,0.3); margin-bottom: 5px;
    }
    .meta-value { font-size: 0.85rem; color: #cbd5e1; font-weight: 500; }
    .meta-value.small { font-size: 0.78rem; color: rgba(255,255,255,0.4); }

    /* ── STATUS INDICATOR ── */
    .status-dot {
      display: inline-block; width: 8px; height: 8px;
      border-radius: 50%; margin-right: 6px;
    }
    .status-dot.unread { background: #f59e0b; box-shadow: 0 0 6px rgba(245,158,11,0.5); }
    .status-dot.read { background: #22c55e; }

    /* ── ACTION BUTTONS ── */
    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 10px 18px; border-radius: 9px; font-size: 0.85rem;
      font-weight: 600; font-family: 'Inter', sans-serif; cursor: pointer;
      border: none; text-decoration: none; transition: all 0.15s;
    }
    .btn-primary {
      background: linear-gradient(135deg, #0891b2, #0e7490);
      color: white;
    }
    .btn-primary:hover { opacity: 0.88; }
    .btn-ghost {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      color: rgba(255,255,255,0.7);
    }
    .btn-ghost:hover { background: rgba(255,255,255,0.1); color: white; }
    .btn-danger {
      background: rgba(239,68,68,0.12);
      border: 1px solid rgba(239,68,68,0.2);
      color: #fca5a5;
    }
    .btn-danger:hover { background: rgba(239,68,68,0.2); }
    .btn-block { width: 100%; justify-content: center; margin-bottom: 10px; }

    /* ── REPLY HINT ── */
    .reply-hint {
      background: rgba(8,145,178,0.08); border: 1px solid rgba(8,145,178,0.2);
      border-radius: 12px; padding: 16px; margin-top: 20px;
    }
    .reply-hint-title { font-size: 0.78rem; font-weight: 700; color: #38bdf8; margin-bottom: 6px; }
    .reply-hint-text { font-size: 0.78rem; color: rgba(255,255,255,0.4); line-height: 1.5; }
    .reply-hint-text a { color: #38bdf8; text-decoration: none; }
    .reply-hint-text a:hover { text-decoration: underline; }

    @media (max-width: 900px) {
      .sub-grid { grid-template-columns: 1fr; }
      .sidebar { display: none; }
      .field-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <!-- SIDEBAR -->
  <nav class="sidebar">
    <div class="sidebar-brand">
      <div class="sidebar-brand-row">
        <div class="sidebar-icon">F</div>
        <div>
          <div class="sidebar-brand-name">FinRise Advisors</div>
          <div class="sidebar-brand-sub">Admin Portal</div>
        </div>
      </div>
    </div>
    <div class="sidebar-nav">
      <a href="/admin" class="active">
        <span class="icon">&#9993;</span> Submissions
      </a>
      <a href="/" target="_blank">
        <span class="icon">&#127760;</span> View Website
      </a>
      <a href="/contact-us" target="_blank">
        <span class="icon">&#128203;</span> Contact Form
      </a>
    </div>
    <div class="sidebar-footer">
      <a href="/admin/logout">
        <span class="icon">&#8594;</span> Sign Out
      </a>
    </div>
  </nav>

  <!-- MAIN -->
  <div class="main">
    <!-- TOP BAR -->
    <div class="topbar">
      <a href="/admin" class="back-btn">&#8592; All Submissions</a>
      <span class="topbar-title">
        Submission from <%= submission.name || 'Unknown' %>
      </span>
      <div class="topbar-actions">
        <form method="POST" action="/admin/mark/<%= submission._id %>">
          <button type="submit" class="btn btn-ghost" style="padding:8px 14px; font-size:0.8rem;">
            <% if (submission.read) { %>
              &#9679; Mark Unread
            <% } else { %>
              &#10003; Mark Read
            <% } %>
          </button>
        </form>
      </div>
    </div>

    <!-- CONTENT -->
    <div class="content">
      <div class="sub-grid">

        <!-- LEFT: SUBMISSION DETAIL -->
        <div>
          <div class="card">
            <div class="card-header">
              <h2>Contact Details</h2>
              <span class="badge <%= submission.source === 'resource' ? 'badge-teal' : 'badge-slate' %>">
                <%= submission.source === 'resource' ? 'Resource Download' : 'Contact Form' %>
              </span>
            </div>
            <div class="card-body">
              <div class="field-row">
                <div class="field">
                  <div class="field-label">Full Name</div>
                  <div class="field-value <%= !submission.name ? 'empty' : '' %>">
                    <%= submission.name || '—' %>
                  </div>
                </div>
                <div class="field">
                  <div class="field-label">Company</div>
                  <div class="field-value <%= !submission.company ? 'empty' : '' %>">
                    <%= submission.company || '—' %>
                  </div>
                </div>
              </div>

              <div class="field-row">
                <div class="field">
                  <div class="field-label">Email Address</div>
                  <div class="field-value <%= !submission.email ? 'empty' : '' %>">
                    <% if (submission.email) { %>
                      <a href="mailto:<%= submission.email %>"><%= submission.email %></a>
                    <% } else { %>
                      —
                    <% } %>
                  </div>
                </div>
                <div class="field">
                  <div class="field-label">Phone Number</div>
                  <div class="field-value <%= !submission.phone ? 'empty' : '' %>">
                    <% if (submission.phone) { %>
                      <a href="tel:<%= submission.phone %>"><%= submission.phone %></a>
                    <% } else { %>
                      —
                    <% } %>
                  </div>
                </div>
              </div>

              <div class="field-full">
                <div class="field-label">Service Interested In</div>
                <div class="field-value">
                  <% if (submission.service) { %>
                    <span class="badge badge-teal"><%= submission.service %></span>
                  <% } else { %>
                    <span class="field-value empty">—</span>
                  <% } %>
                </div>
              </div>

              <% if (submission.resource) { %>
              <div class="field-full">
                <div class="field-label">Resource Requested</div>
                <div class="field-value"><%= submission.resource %></div>
              </div>
              <% } %>

              <hr class="divider">

              <div class="field-full">
                <div class="field-label">Message</div>
                <% if (submission.message) { %>
                  <div class="message-box"><%= submission.message %></div>
                <% } else { %>
                  <div class="field-value empty" style="margin-top:6px;">No message provided.</div>
                <% } %>
              </div>
            </div>
          </div>

          <!-- Reply hint -->
          <div class="reply-hint">
            <div class="reply-hint-title">&#9993; Quick Reply</div>
            <div class="reply-hint-text">
              Reply directly via your email client:
              <a href="mailto:<%= submission.email %>?subject=Re: Your inquiry to FinRise Advisors&body=Hi <%= submission.name %>,%0A%0AThank you for reaching out to FinRise Advisors.%0A%0A">
                Send Email to <%= submission.email || 'N/A' %>
              </a>
            </div>
          </div>
        </div>

        <!-- RIGHT: META / ACTIONS -->
        <div>
          <!-- Status card -->
          <div class="card" style="margin-bottom:16px;">
            <div class="card-header">
              <h2>Submission Info</h2>
            </div>
            <div class="card-body">
              <div class="meta-item">
                <div class="meta-label">Status</div>
                <div class="meta-value">
                  <span class="status-dot <%= submission.read ? 'read' : 'unread' %>"></span>
                  <%= submission.read ? 'Read' : 'Unread' %>
                </div>
              </div>
              <div class="meta-item">
                <div class="meta-label">Received</div>
                <div class="meta-value">
                  <%= new Date(submission.createdAt).toLocaleDateString('en-US', { weekday: 'short', year: 'numeric', month: 'long', day: 'numeric' }) %>
                </div>
                <div class="meta-value small">
                  <%= new Date(submission.createdAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %> (server time)
                </div>
              </div>
              <div class="meta-item">
                <div class="meta-label">Source</div>
                <div class="meta-value"><%= submission.source === 'resource' ? 'Resource Download' : 'Contact Form' %></div>
              </div>
              <% if (submission.ipAddress) { %>
              <div class="meta-item">
                <div class="meta-label">IP Address</div>
                <div class="meta-value small"><%= submission.ipAddress %></div>
              </div>
              <% } %>
              <div class="meta-item">
                <div class="meta-label">Submission ID</div>
                <div class="meta-value small" style="font-family: monospace; font-size:0.7rem;">
                  <%= submission._id %>
                </div>
              </div>
            </div>
          </div>

          <!-- Actions card -->
          <div class="card">
            <div class="card-header">
              <h2>Actions</h2>
            </div>
            <div class="card-body">
              <% if (submission.email) { %>
              <a href="mailto:<%= submission.email %>?subject=Re: Your inquiry to FinRise Advisors&body=Hi <%= submission.name %>,%0A%0AThank you for reaching out to FinRise Advisors.%0A%0A"
                 class="btn btn-primary btn-block">
                &#9993; Reply via Email
              </a>
              <% } %>

              <form method="POST" action="/admin/mark/<%= submission._id %>">
                <button type="submit" class="btn btn-ghost btn-block">
                  <% if (submission.read) { %>
                    &#9679; Mark as Unread
                  <% } else { %>
                    &#10003; Mark as Read
                  <% } %>
                </button>
              </form>

              <form method="POST" action="/admin/delete/<%= submission._id %>"
                    onsubmit="return confirm('Permanently delete this submission? This cannot be undone.')">
                <button type="submit" class="btn btn-danger btn-block" style="margin-bottom:0;">
                  &#128465; Delete Submission
                </button>
              </form>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

</body>
</html>
